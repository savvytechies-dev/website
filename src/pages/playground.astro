---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="OIDC / JWT Playground — SavvyTechies"
  description="Decode & verify JWTs against a JWKS, inspect OIDC discovery documents, and generate PKCE challenges — all in your browser. Nothing is sent to a server."
>
  <Navigation />

  <section class="bg-gradient-to-br from-primary-600 to-secondary-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">OIDC / JWT Playground</h1>
      <p class="text-xl text-indigo-100 mb-4">
        Decode &amp; verify JWTs, inspect OIDC discovery, and generate PKCE — right in your browser.
      </p>
      <p class="inline-flex items-center gap-2 text-sm bg-white/15 rounded-full px-4 py-1.5">
        🔒 Everything runs client-side. Tokens never leave your browser.
      </p>
    </div>
  </section>

  <section class="py-10 bg-gray-50 min-h-[60vh]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 mb-6 flex-wrap" role="tablist">
        <button data-pg="jwt" class="pg-tab bg-primary-600 text-white px-4 py-2 rounded-lg font-semibold">Decode & verify JWT</button>
        <button data-pg="oidc" class="pg-tab bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-lg font-semibold">OIDC discovery</button>
        <button data-pg="pkce" class="pg-tab bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-lg font-semibold">PKCE generator</button>
      </div>

      <!-- JWT -->
      <div id="pg-jwt" class="pg-panel">
        <label class="block text-sm font-semibold text-gray-700 mb-2">JWT</label>
        <textarea id="jwt-in" rows="5" spellcheck="false"
          class="w-full font-mono text-xs p-3 border border-gray-300 rounded-lg"
          placeholder="eyJhbGciOiJSUzI1NiIsImtpZCI6Ii4uLiJ9.eyJzdWIiOiIuLi4ifQ.signature"></textarea>
        <div class="flex items-center gap-3 mt-3 flex-wrap">
          <input id="jwks-in" type="url"
            class="flex-1 min-w-[240px] text-sm p-2 border border-gray-300 rounded-lg"
            placeholder="JWKS URL (optional, to verify signature) — e.g. https://auth…/realms/acme/protocol/openid-connect/certs" />
          <button id="jwt-go" class="bg-primary-600 text-white font-semibold px-5 py-2 rounded-lg">Decode</button>
        </div>
        <div class="flex items-center gap-2 mt-2 text-sm flex-wrap">
          <span class="text-gray-500">New here?</span>
          <button id="jwt-example" class="text-primary-600 font-medium hover:underline">Load a sample token</button>
          <span class="text-gray-300">·</span>
          <button id="jwt-copy" class="text-primary-600 font-medium hover:underline">Copy it</button>
          <span class="text-gray-400 text-xs">— decodes as-is; add a JWKS to verify your own.</span>
        </div>
        <div id="jwt-out" class="mt-4 hidden"></div>
      </div>

      <!-- OIDC -->
      <div id="pg-oidc" class="pg-panel hidden">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Issuer URL</label>
        <div class="flex items-center gap-3 flex-wrap">
          <input id="oidc-in" type="url"
            class="flex-1 min-w-[240px] text-sm p-2 border border-gray-300 rounded-lg"
            placeholder="https://auth.savvytechies.com/realms/acme-prod" />
          <button id="oidc-go" class="bg-primary-600 text-white font-semibold px-5 py-2 rounded-lg">Fetch</button>
        </div>
        <p class="text-xs text-gray-500 mt-2">Fetches <code>&lt;issuer&gt;/.well-known/openid-configuration</code>.</p>
        <div class="flex items-center gap-2 mt-2 text-sm flex-wrap">
          <span class="text-gray-500">Example:</span>
          <button id="oidc-example" class="text-primary-600 font-medium hover:underline">Load a live SavvyTechies realm</button>
          <span class="text-gray-400 text-xs">— a real, public discovery document.</span>
        </div>
        <div id="oidc-out" class="mt-4 hidden"></div>
      </div>

      <!-- PKCE -->
      <div id="pg-pkce" class="pg-panel hidden">
        <p class="text-sm text-gray-600 mb-3">Generate a PKCE <code>code_verifier</code> and its S256 <code>code_challenge</code> for an Authorization Code + PKCE flow.</p>
        <button id="pkce-go" class="bg-primary-600 text-white font-semibold px-5 py-2 rounded-lg">Generate PKCE pair</button>
        <div id="pkce-out" class="mt-4 hidden"></div>
      </div>

      <div id="pg-error" class="mt-4 text-sm text-red-600"></div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .kv { border-collapse: collapse; width: 100%; font-size: 0.85rem; }
  .kv td { border: 1px solid #e5e7eb; padding: 0.4rem 0.6rem; vertical-align: top; }
  .kv td:first-child { font-weight: 600; width: 34%; white-space: nowrap; color: #374151; }
  pre.code { background: #1c1e26; color: #e6e8ef; padding: 0.8rem; border-radius: 8px; overflow-x: auto; font-size: 0.78rem; }
  .ok { color: #157347; font-weight: 700; }
  .bad { color: #b42318; font-weight: 700; }
</style>

<script>
  const $ = (id) => document.getElementById(id);
  const err = (m) => ($('pg-error').textContent = m || '');
  const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]);

  // --- ready-to-run examples (so the boxes are never a blank wall) ---
  // A syntactically real RS256 access token with typical Keycloak claims. It
  // decodes as-is (the signature is a placeholder — decoding never checks it).
  const SAMPLE_JWT =
    'eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6InNUOXhRMl9rRXhhbXBsZVNpZ25pbmdLZXkwMSJ9..NHVaYe26MbtOYhSKkoKYdFVomg4i8ZJd8_-RU8VNbftc4TSMb4bXP3l3YlNWACwyXPGffz5aXHc6lty1Y2t4SWRqGteragsVdZufDn5BlnJl9pdR_kdVFUsra2rWKEofkZeIC4yWytE58sMIihvo9H1ScmmVwBcQP6XETqYd0aSHp1gOa9RdUPDvoXQ5oqygTqVtxaDr6wUFKrKItgBMzWIdNZ6y7O9E0DhEPTbE9rfBo6KTFsHAZnMg4k68CDp2woYIaXbmYTWcvbzIuHO7_37GT79XdIwkm95QJ7hYC9RiwrV7mesbY4PAah0R1u';
  // A real, public Keycloak realm — its discovery document actually loads.
  const SAMPLE_ISSUER = 'https://auth.savvytechies.com/realms/savvytechies';

  // --- tabs ---
  document.querySelectorAll('.pg-tab').forEach((b) =>
    b.addEventListener('click', () => {
      err('');
      const key = b.getAttribute('data-pg');
      document.querySelectorAll('.pg-tab').forEach((x) => {
        const on = x === b;
        x.className = 'pg-tab px-4 py-2 rounded-lg font-semibold ' +
          (on ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-300');
      });
      document.querySelectorAll('.pg-panel').forEach((p) => p.classList.add('hidden'));
      $('pg-' + key).classList.remove('hidden');
    }),
  );

  // --- base64url ---
  function b64urlToBytes(s) {
    s = s.replace(/-/g, '+').replace(/_/g, '/');
    while (s.length % 4) s += '=';
    const bin = atob(s);
    const out = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i);
    return out;
  }
  function b64urlToStr(s) {
    return new TextDecoder().decode(b64urlToBytes(s));
  }
  function bytesToB64url(bytes) {
    let bin = '';
    bytes.forEach((b) => (bin += String.fromCharCode(b)));
    return btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }

  function claimsTable(obj) {
    const timeKeys = { exp: 1, iat: 1, nbf: 1, auth_time: 1 };
    const rows = Object.entries(obj).map(([k, v]) => {
      let disp = typeof v === 'object' ? JSON.stringify(v) : String(v);
      if (timeKeys[k] && typeof v === 'number') disp += ` (${new Date(v * 1000).toISOString()})`;
      return `<tr><td>${esc(k)}</td><td>${esc(disp)}</td></tr>`;
    });
    return `<table class="kv">${rows.join('')}</table>`;
  }

  // --- JWT decode + verify ---
  async function verifyJwt(token, jwksUrl) {
    const parts = token.trim().split('.');
    if (parts.length !== 3) throw new Error('A JWT has three dot-separated parts.');
    const header = JSON.parse(b64urlToStr(parts[0]));
    const payload = JSON.parse(b64urlToStr(parts[1]));
    let verify = '';
    if (jwksUrl) {
      try {
        const jwks = await (await fetch(jwksUrl)).json();
        const key = (jwks.keys || []).find((k) => k.kid === header.kid) || (jwks.keys || [])[0];
        if (!key) throw new Error('no matching key in JWKS');
        const algo =
          header.alg === 'ES256'
            ? { name: 'ECDSA', namedCurve: 'P-256' }
            : { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-256' };
        const verifyAlgo = header.alg === 'ES256' ? { name: 'ECDSA', hash: 'SHA-256' } : algo;
        const cryptoKey = await crypto.subtle.importKey('jwk', key, algo, false, ['verify']);
        const data = new TextEncoder().encode(parts[0] + '.' + parts[1]);
        const sig = b64urlToBytes(parts[2]);
        const ok = await crypto.subtle.verify(verifyAlgo, cryptoKey, sig, data);
        verify = ok
          ? `<p class="ok mt-2">✓ Signature valid (alg ${esc(header.alg)}, kid ${esc(header.kid || '—')})</p>`
          : `<p class="bad mt-2">✗ Signature does NOT verify against this JWKS.</p>`;
        if (ok && payload.exp && payload.exp * 1000 < Date.now())
          verify += `<p class="bad">✗ Token is expired.</p>`;
      } catch (e) {
        verify = `<p class="bad mt-2">Could not verify: ${esc(e.message)} (CORS on the JWKS URL is common).</p>`;
      }
    }
    return { header, payload, verify };
  }

  $('jwt-go').addEventListener('click', async () => {
    err('');
    $('jwt-out').classList.add('hidden');
    try {
      const { header, payload, verify } = await verifyJwt($('jwt-in').value, $('jwks-in').value.trim());
      $('jwt-out').innerHTML =
        `<h3 class="font-bold mb-1">Header</h3>${claimsTable(header)}` +
        `<h3 class="font-bold mb-1 mt-4">Payload (claims)</h3>${claimsTable(payload)}${verify}`;
      $('jwt-out').classList.remove('hidden');
    } catch (e) {
      err(e.message);
    }
  });

  // --- OIDC discovery ---
  $('oidc-go').addEventListener('click', async () => {
    err('');
    $('oidc-out').classList.add('hidden');
    try {
      const issuer = $('oidc-in').value.trim().replace(/\/$/, '');
      if (!issuer) return;
      const doc = await (await fetch(issuer + '/.well-known/openid-configuration')).json();
      const pick = ['issuer', 'authorization_endpoint', 'token_endpoint', 'userinfo_endpoint',
        'jwks_uri', 'end_session_endpoint', 'introspection_endpoint'];
      const rows = pick.filter((k) => doc[k]).map((k) => `<tr><td>${k}</td><td>${esc(doc[k])}</td></tr>`);
      const lists = ['scopes_supported', 'grant_types_supported', 'response_types_supported',
        'id_token_signing_alg_values_supported']
        .filter((k) => doc[k])
        .map((k) => `<tr><td>${k}</td><td>${esc((doc[k] || []).join(', '))}</td></tr>`);
      const jwksBtn = doc.jwks_uri
        ? `<button id="use-jwks" class="mt-3 text-primary-600 font-semibold text-sm underline">Use this JWKS in the JWT tab →</button>`
        : '';
      $('oidc-out').innerHTML = `<table class="kv">${rows.join('')}${lists.join('')}</table>${jwksBtn}`;
      $('oidc-out').classList.remove('hidden');
      if (doc.jwks_uri) {
        $('use-jwks').addEventListener('click', () => {
          $('jwks-in').value = doc.jwks_uri;
          document.querySelector('[data-pg="jwt"]').click();
        });
      }
    } catch (e) {
      err('Could not fetch the discovery document (CORS or a wrong issuer URL): ' + e.message);
    }
  });

  // --- PKCE ---
  $('pkce-go').addEventListener('click', async () => {
    err('');
    const bytes = crypto.getRandomValues(new Uint8Array(32));
    const verifier = bytesToB64url(bytes);
    const digest = new Uint8Array(await crypto.subtle.digest('SHA-256', new TextEncoder().encode(verifier)));
    const challenge = bytesToB64url(digest);
    $('pkce-out').innerHTML =
      `<table class="kv">
        <tr><td>code_verifier</td><td><code>${esc(verifier)}</code></td></tr>
        <tr><td>code_challenge</td><td><code>${esc(challenge)}</code></td></tr>
        <tr><td>code_challenge_method</td><td>S256</td></tr>
      </table>
      <p class="text-xs text-gray-500 mt-2">Send the challenge on /authorize; send the verifier on /token. Generate a fresh pair per login.</p>`;
    $('pkce-out').classList.remove('hidden');
  });

  // --- examples: prefill the boxes on load + explicit "load"/"copy" buttons ---
  function loadJwtExample() {
    $('jwt-in').value = SAMPLE_JWT;
    err('');
    $('jwt-go').click();
  }
  function loadOidcExample() {
    $('oidc-in').value = SAMPLE_ISSUER;
    err('');
    $('oidc-go').click();
  }
  $('jwt-example').addEventListener('click', loadJwtExample);
  $('oidc-example').addEventListener('click', loadOidcExample);
  $('jwt-copy').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText($('jwt-in').value || SAMPLE_JWT);
      const b = $('jwt-copy');
      const prev = b.textContent;
      b.textContent = 'Copied ✓';
      setTimeout(() => (b.textContent = prev), 1500);
    } catch {
      err('Clipboard blocked — select the token and copy manually.');
    }
  });

  // Seed the boxes so a first-time visitor sees working input, not blank fields.
  // (Only prefill; we don't auto-run, so nothing surprises them.)
  if (!$('jwt-in').value) $('jwt-in').value = SAMPLE_JWT;
  if (!$('oidc-in').value) $('oidc-in').value = SAMPLE_ISSUER;
</script>
