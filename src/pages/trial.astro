---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Start Free - SavvyTechies" description="Start on the SavvyTechies free tier: managed Keycloak free forever for up to 1,000 monthly active users and 3 realms. No credit card required.">
  <Navigation />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-600 to-secondary-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Start on the free tier
      </h1>
      <p class="text-xl text-indigo-100 mb-6">
        Managed Keycloak, <strong>free forever</strong> — up to 1,000 monthly active users and 3 realms. Full feature access.
      </p>
      <div class="flex items-center justify-center space-x-6 text-sm">
        <div class="flex items-center">
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>No credit card required</span>
        </div>
        <div class="flex items-center">
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Full feature access</span>
        </div>
        <div class="flex items-center">
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Free forever</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Trial Signup Form -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl shadow-xl p-8">
        <h2 class="text-2xl font-bold mb-6 text-center">Create Your Account</h2>

        <form class="space-y-6">
          <!-- Personal Info -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-medium text-gray-700 mb-2">
                First Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="first_name"
                name="first_name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              />
            </div>
            <div>
              <label for="last_name" class="block text-sm font-medium text-gray-700 mb-2">
                Last Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="last_name"
                name="last_name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Work Email <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              placeholder="you@company.com"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-gray-700 mb-2">
              Company Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              placeholder="+1 (555) 123-4567"
            />
          </div>

          <!-- Service Selection -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3">
              Which services are you interested in? <span class="text-red-500">*</span>
            </label>
            <div class="space-y-2">
              <label class="flex items-center">
                <input type="checkbox" name="services[]" value="keycloak" class="rounded text-primary-600 focus:ring-primary-500 h-5 w-5">
                <span class="ml-3 text-gray-700">Managed Keycloak (Authentication & SSO)</span>
              </label>
              <label class="flex items-center">
                <input type="checkbox" name="services[]" value="authorization" class="rounded text-primary-600 focus:ring-primary-500 h-5 w-5">
                <span class="ml-3 text-gray-700">Managed Authorization — fine-grained authz <span class="text-amber-600 text-xs font-semibold">(roadmap)</span></span>
              </label>
              <label class="flex items-center">
                <input type="checkbox" name="services[]" value="secrets" class="rounded text-primary-600 focus:ring-primary-500 h-5 w-5">
                <span class="ml-3 text-gray-700">Managed Secrets — secrets & PKI <span class="text-amber-600 text-xs font-semibold">(roadmap)</span></span>
              </label>
            </div>
          </div>

          <!-- Cloud Provider -->
          <div>
            <label for="cloud_provider" class="block text-sm font-medium text-gray-700 mb-2">
              Preferred Cloud Provider
            </label>
            <select
              id="cloud_provider"
              name="cloud_provider"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            >
              <option value="">Select a provider</option>
              <option value="aws">Amazon Web Services (AWS)</option>
              <option value="azure">Microsoft Azure</option>
              <option value="gcp">Google Cloud Platform (GCP)</option>
              <option value="multi">Multi-Cloud</option>
              <option value="undecided">Not sure yet</option>
            </select>
          </div>

          <!-- Use Case -->
          <div>
            <label for="use_case" class="block text-sm font-medium text-gray-700 mb-2">
              What's your primary use case?
            </label>
            <textarea
              id="use_case"
              name="use_case"
              rows="3"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              placeholder="Tell us about your project and requirements..."
            ></textarea>
          </div>

          <!-- Terms -->
          <div class="flex items-start">
            <input
              type="checkbox"
              id="terms"
              name="terms"
              required
              class="rounded text-primary-600 focus:ring-primary-500 h-5 w-5 mt-1"
            >
            <label for="terms" class="ml-3 text-sm text-gray-600">
              I agree to the <a href="/terms" class="text-primary-600 hover:text-primary-700">Terms of Service</a>
              and <a href="/privacy" class="text-primary-600 hover:text-primary-700">Privacy Policy</a>
            </label>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full bg-primary-600 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-primary-700 transition shadow-lg"
          >
            Start Free
          </button>

          <p class="text-center text-sm text-gray-500">
            Your free-tier workspace is ready immediately. No credit card required.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">What's in the Free Tier</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Full Feature Access</h3>
          <p class="text-gray-600">
            Experience all enterprise features including multi-cloud deployment, auto-scaling, and AI monitoring.
          </p>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Dedicated Support</h3>
          <p class="text-gray-600">
            Direct access to our solutions architects for onboarding help and technical questions.
          </p>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">No Commitment</h3>
          <p class="text-gray-600">
            Free forever on the free tier — no credit card. Upgrade only when you outgrow 1,000 MAUs or 3 realms.
          </p>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Custom Configuration</h3>
          <p class="text-gray-600">
            Set up your services with your preferred cloud provider and region settings.
          </p>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Real-Time Monitoring</h3>
          <p class="text-gray-600">
            Access to comprehensive dashboards with metrics, logs, and performance insights.
          </p>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Documentation & Guides</h3>
          <p class="text-gray-600">
            Complete API docs, quickstart guides, and integration examples for all services.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Getting Started</h2>

      <div class="space-y-8">
        <div class="flex items-start">
          <div class="bg-primary-600 text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg flex-shrink-0">
            1
          </div>
          <div class="ml-6">
            <h3 class="text-xl font-bold mb-2">Sign Up (2 minutes)</h3>
            <p class="text-gray-600">
              Fill out the form above. No credit card required. Get instant access to your free workspace.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-primary-600 text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg flex-shrink-0">
            2
          </div>
          <div class="ml-6">
            <h3 class="text-xl font-bold mb-2">Configure Your Services (15 minutes)</h3>
            <p class="text-gray-600">
              Choose your cloud provider, region, and service settings. Our onboarding wizard guides you through the process.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-primary-600 text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg flex-shrink-0">
            3
          </div>
          <div class="ml-6">
            <h3 class="text-xl font-bold mb-2">Deploy & Test (Days 1-5)</h3>
            <p class="text-gray-600">
              Connect your applications, run load tests, explore features. Our team is available to help you succeed.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-primary-600 text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg flex-shrink-0">
            4
          </div>
          <div class="ml-6">
            <h3 class="text-xl font-bold mb-2">Review & Decide (Days 6-7)</h3>
            <p class="text-gray-600">
              Meet with our team to review your experience. Choose a plan that fits your needs or walk away—no questions asked.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Free Tier FAQs</h2>

      <div class="space-y-6">
        <div class="border-b pb-6">
          <h3 class="text-lg font-bold mb-2">Do I need a credit card?</h3>
          <p class="text-gray-600">
            No — the free tier needs no payment information. You get full feature access up to 1,000 monthly active users and 3 realms.
          </p>
        </div>

        <div class="border-b pb-6">
          <h3 class="text-lg font-bold mb-2">What happens if I exceed the free tier?</h3>
          <p class="text-gray-600">
            If you pass 1,000 monthly active users or need more than 3 realms, we'll prompt you to upgrade to a paid plan; your workspace keeps running while you decide. Nothing is deleted out from under you.
          </p>
        </div>

        <div class="border-b pb-6">
          <h3 class="text-lg font-bold mb-2">What is included on the free tier?</h3>
          <p class="text-gray-600">
            The free tier is full access to Managed Keycloak (up to 1,000 MAUs & 3 realms). Managed Authorization and Managed Secrets are on our roadmap — tell us on the form if you'd like early access.
          </p>
        </div>

        <div class="border-b pb-6">
          <h3 class="text-lg font-bold mb-2">What support do I get?</h3>
          <p class="text-gray-600">
            Free-tier users get email support with response times under 4 hours during business hours. We also offer optional onboarding calls with our solutions architects.
          </p>
        </div>

        <div class="border-b pb-6">
          <h3 class="text-lg font-bold mb-2">What are the free-tier limits?</h3>
          <p class="text-gray-600">
            The free tier includes up to 1,000 monthly active users and 3 realms, with full feature access. Need more? Upgrade to a paid plan anytime.
          </p>
        </div>

        <div class="pb-6">
          <h3 class="text-lg font-bold mb-2">Can I extend my trial?</h3>
          <p class="text-gray-600">
            Staying under 1,000 MAUs and 3 realms? You can run on the free tier indefinitely. When you outgrow it, upgrading is a click — no migration.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 bg-gradient-to-br from-primary-600 to-secondary-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-indigo-100 mb-8">
        Join hundreds of companies using SavvyTechies for their critical infrastructure
      </p>
      <a href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;" class="inline-block bg-white text-primary-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition shadow-lg">
        Start Free
      </a>
    </div>
  </section>

  <Footer />
</Layout>
