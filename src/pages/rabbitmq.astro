---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import RabbitMQArchitecture from '../components/RabbitMQArchitecture';
---

<Layout title="Managed RabbitMQ - SavvyTechies" description="Enterprise-grade managed RabbitMQ message broker with multi-cloud deployment, auto-scaling, and 99.99% availability.">
  <Navigation />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-orange-500 to-red-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class="text-6xl mb-4">🐰</div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Managed RabbitMQ
        </h1>
        <p class="text-xl md:text-2xl text-orange-100 max-w-3xl mx-auto mb-8">
          Reliable message queuing with automatic clustering, monitoring, and scaling
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="https://console.savvytechies.com/signup" class="bg-white text-orange-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition shadow-lg">
            Start Free 7-Day Trial
          </a>
          <a href="/#contact" class="bg-red-700 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-red-800 transition border-2 border-white">
            Contact Sales
          </a>
        </div>
        <p class="text-sm text-orange-100 mt-4">
          No credit card required • Full access to all features • Cancel anytime
        </p>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Reliable Message Delivery at Scale</h2>
          <p class="text-lg text-gray-700 mb-4">
            RabbitMQ is the world's most popular open-source message broker, trusted by enterprises globally for reliable asynchronous communication.
          </p>
          <p class="text-lg text-gray-700 mb-6">
            We provide a fully managed RabbitMQ service that handles all operational complexity including clustering, failover, monitoring, and scaling.
          </p>
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">High Availability Clustering</div>
                <div class="text-gray-600">Automatic failover with mirrored queues across nodes</div>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">Smart Auto-Scaling</div>
                <div class="text-gray-600">Dynamically adjust capacity based on queue depth and throughput</div>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">Real-Time Monitoring</div>
                <div class="text-gray-600">Comprehensive metrics and alerting with AI anomaly detection</div>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-xl p-8">
          <h3 class="text-2xl font-bold mb-6">Key Capabilities</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </span>
              <span>AMQP 0-9-1 Protocol</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
              </span>
              <span>Flexible Routing (Direct, Topic, Fanout)</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </span>
              <span>Message Persistence & Durability</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </span>
              <span>TLS Encryption & Authentication</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </span>
              <span>Dead Letter Exchanges (DLX)</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Message TTL & Delayed Delivery</span>
            </div>
            <div class="flex items-center">
              <span class="bg-orange-100 text-orange-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                </svg>
              </span>
              <span>Management UI & APIs</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">High-Availability Architecture</h2>
      <div class="bg-white rounded-xl shadow-lg p-8">
        <RabbitMQArchitecture client:load />
      </div>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Common Use Cases</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">📧</div>
          <h3 class="text-xl font-bold mb-3">Email & Notifications</h3>
          <p class="text-gray-600">
            Decouple notification sending from your main application. Queue email, SMS, and push notifications for reliable delivery.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">⚙️</div>
          <h3 class="text-xl font-bold mb-3">Background Jobs</h3>
          <p class="text-gray-600">
            Process long-running tasks asynchronously. Image resizing, report generation, and data processing without blocking users.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">🔄</div>
          <h3 class="text-xl font-bold mb-3">Microservices Communication</h3>
          <p class="text-gray-600">
            Enable loosely-coupled communication between microservices with guaranteed message delivery and retry logic.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">📊</div>
          <h3 class="text-xl font-bold mb-3">Event-Driven Architecture</h3>
          <p class="text-gray-600">
            Build event-driven systems where services react to domain events. Perfect for CQRS and event sourcing patterns.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">🔁</div>
          <h3 class="text-xl font-bold mb-3">Work Queue Distribution</h3>
          <p class="text-gray-600">
            Distribute work across multiple workers with automatic load balancing and fair dispatch algorithms.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-lg">
          <div class="text-3xl mb-4">🌐</div>
          <h3 class="text-xl font-bold mb-3">Webhooks & API Integration</h3>
          <p class="text-gray-600">
            Buffer and retry webhook deliveries. Integrate with external APIs reliably even during outages.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Why Our Managed RabbitMQ?</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Zero Message Loss</h3>
            <p class="text-gray-600">
              Publisher confirms, persistent queues, and mirrored clustering ensure messages are never lost even during failures.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Automatic Scaling</h3>
            <p class="text-gray-600">
              AI-powered scaling adjusts cluster size based on queue depth, consumer lag, and throughput patterns.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Deep Observability</h3>
            <p class="text-gray-600">
              Real-time metrics on queue depth, throughput, consumer performance, and memory usage with historical analytics.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Automated Backups</h3>
            <p class="text-gray-600">
              Daily automated backups of queue definitions, exchanges, and configurations with point-in-time recovery.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Expert Support</h3>
            <p class="text-gray-600">
              Our RabbitMQ experts are available 24/7 to help with architecture design, performance tuning, and troubleshooting.
            </p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="bg-orange-100 rounded-lg p-3 mr-4">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Multi-Cloud Deployment</h3>
            <p class="text-gray-600">
              Deploy across AWS, Azure, and GCP with federation for cross-cloud message routing and disaster recovery.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-6">Easy Migration from Existing RabbitMQ</h2>
      <p class="text-lg text-gray-600 mb-8">
        We handle the entire migration process with zero downtime. Export your configurations, queues, and messages, then import seamlessly into our managed platform.
      </p>
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h3 class="text-xl font-bold mb-4">Migration Process</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="text-center">
            <div class="bg-orange-100 rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-2">
              <span class="text-xl font-bold text-orange-600">1</span>
            </div>
            <div class="font-semibold mb-1">Assessment</div>
            <div class="text-sm text-gray-600">Analyze current setup</div>
          </div>
          <div class="text-center">
            <div class="bg-orange-100 rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-2">
              <span class="text-xl font-bold text-orange-600">2</span>
            </div>
            <div class="font-semibold mb-1">Parallel Deploy</div>
            <div class="text-sm text-gray-600">Set up managed cluster</div>
          </div>
          <div class="text-center">
            <div class="bg-orange-100 rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-2">
              <span class="text-xl font-bold text-orange-600">3</span>
            </div>
            <div class="font-semibold mb-1">Traffic Switch</div>
            <div class="text-sm text-gray-600">Gradual cutover</div>
          </div>
          <div class="text-center">
            <div class="bg-orange-100 rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-2">
              <span class="text-xl font-bold text-orange-600">4</span>
            </div>
            <div class="font-semibold mb-1">Validation</div>
            <div class="text-sm text-gray-600">Verify & decommission old</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-br from-orange-500 to-red-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Start with Managed RabbitMQ Today</h2>
      <p class="text-xl text-orange-100 mb-8">
        Get enterprise reliability without the operational complexity
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-white text-orange-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition">
          Request Demo
        </a>
        <a href="/#pricing" class="border-2 border-white text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-white hover:text-orange-600 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
