        // Fair Use Policy modal
        const fairUseModal = document.getElementById('fair-use-modal');
        const openFairUse = () => fairUseModal?.showModal();
        const closeFairUse = () => fairUseModal?.close();
        document.getElementById('fair-use-link')?.addEventListener('click', openFairUse);
