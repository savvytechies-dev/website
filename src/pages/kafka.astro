---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import KafkaArchitecture from '../components/KafkaArchitecture';
---

<Layout title="Managed Kafka - SavvyTechies" description="Enterprise-grade managed Apache Kafka for event streaming with multi-region replication, auto-scaling, and 99.99% availability.">
  <Navigation />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-purple-600 to-indigo-700 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class="text-6xl mb-4">⚡</div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Managed Apache Kafka
        </h1>
        <p class="text-xl md:text-2xl text-purple-100 max-w-3xl mx-auto mb-8">
          High-throughput event streaming platform for real-time data pipelines and streaming analytics
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="https://console.savvytechies.com/signup" class="bg-white text-purple-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition shadow-lg">
            Start Free 7-Day Trial
          </a>
          <a href="/#contact" class="bg-indigo-800 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-indigo-900 transition border-2 border-white">
            Contact Sales
          </a>
        </div>
        <p class="text-sm text-purple-100 mt-4">
          No credit card required • Full access to all features • Cancel anytime
        </p>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Event Streaming at Scale</h2>
          <p class="text-lg text-gray-700 mb-4">
            Apache Kafka is the de facto standard for event streaming, powering real-time data pipelines for thousands of companies including LinkedIn, Netflix, and Uber.
          </p>
          <p class="text-lg text-gray-700 mb-6">
            Our managed Kafka service delivers enterprise-grade reliability with multi-region replication, automatic scaling, and comprehensive monitoring—without the operational complexity.
          </p>
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">Massive Throughput</div>
                <div class="text-gray-600">Handle millions of events per second with low latency</div>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">Multi-Region Active-Active</div>
                <div class="text-gray-600">Cross-datacenter replication for global availability</div>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mr-3 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <div class="font-semibold">Exactly-Once Semantics</div>
                <div class="text-gray-600">Guaranteed message delivery without duplicates</div>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-xl p-8">
          <h3 class="text-2xl font-bold mb-6">What's Included</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </span>
              <span>Apache Kafka 3.6+</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                </svg>
              </span>
              <span>Schema Registry (Confluent compatible)</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
              </span>
              <span>Kafka Connect (Source & Sink)</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </span>
              <span>ksqlDB for Stream Processing</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </span>
              <span>TLS/SSL & SASL Authentication</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </span>
              <span>Topic ACLs & Resource Quotas</span>
            </div>
            <div class="flex items-center">
              <span class="bg-purple-100 text-purple-600 rounded-full p-2 mr-3">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                </svg>
              </span>
              <span>Comprehensive Monitoring & Alerting</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Multi-Region Architecture</h2>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <KafkaArchitecture client:load />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="bg-white rounded-lg p-6 shadow">
          <h3 class="text-lg font-bold mb-3">Fault Tolerance</h3>
          <p class="text-gray-600">
            Automatic leader election and partition reassignment ensure continuous operation during broker failures.
          </p>
        </div>
        <div class="bg-white rounded-lg p-6 shadow">
          <h3 class="text-lg font-bold mb-3">Linear Scalability</h3>
          <p class="text-gray-600">
            Add brokers dynamically to increase throughput. Kafka scales horizontally to handle massive workloads.
          </p>
        </div>
        <div class="bg-white rounded-lg p-6 shadow">
          <h3 class="text-lg font-bold mb-3">Zero Data Loss</h3>
          <p class="text-gray-600">
            Replicated partitions across brokers and regions with configurable acknowledgment levels.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Kafka Powers Critical Use Cases</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">🔄</div>
          <h3 class="text-xl font-bold mb-3">Event Sourcing & CQRS</h3>
          <p class="text-gray-600">
            Store all state changes as immutable events. Build materialized views and enable time travel debugging.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">📊</div>
          <h3 class="text-xl font-bold mb-3">Real-Time Analytics</h3>
          <p class="text-gray-600">
            Process streaming data in real-time with Kafka Streams or ksqlDB for instant insights and dashboards.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">🔗</div>
          <h3 class="text-xl font-bold mb-3">Data Integration</h3>
          <p class="text-gray-600">
            Connect databases, data warehouses, and applications with Kafka Connect for unified data pipelines.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">📈</div>
          <h3 class="text-xl font-bold mb-3">Metrics & Logging</h3>
          <p class="text-gray-600">
            Centralize application logs and metrics at massive scale. Feed into Elasticsearch, Splunk, or data lakes.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-3">Change Data Capture (CDC)</h3>
          <p class="text-gray-600">
            Stream database changes in real-time using Debezium. Keep systems synchronized without polling.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <div class="text-3xl mb-4">🤖</div>
          <h3 class="text-xl font-bold mb-3">ML Model Serving</h3>
          <p class="text-gray-600">
            Feed real-time features to ML models. Stream predictions back for immediate action and model feedback.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Enterprise Features</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <h3 class="font-bold">Exactly-Once Delivery</h3>
          </div>
          <p class="text-sm text-gray-600">
            Idempotent producers and transactional writes ensure no duplicates or data loss.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <h3 class="font-bold">Auto-Scaling</h3>
          </div>
          <p class="text-sm text-gray-600">
            AI-driven scaling adds brokers and partitions based on throughput and consumer lag.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
            <h3 class="font-bold">Multi-Cloud Ready</h3>
          </div>
          <p class="text-sm text-gray-600">
            Deploy across AWS, Azure, GCP with MirrorMaker 2 for cross-cloud replication.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="font-bold">Time-Travel Queries</h3>
          </div>
          <p class="text-sm text-gray-600">
            Replay messages from any point in time with configurable retention policies.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <h3 class="font-bold">Schema Evolution</h3>
          </div>
          <p class="text-sm text-gray-600">
            Avro, Protobuf, and JSON Schema support with backward/forward compatibility.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <h3 class="font-bold">Enterprise Security</h3>
          </div>
          <p class="text-sm text-gray-600">
            TLS encryption, SASL authentication, and fine-grained ACLs for topics and consumer groups.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <h3 class="font-bold">Deep Observability</h3>
          </div>
          <p class="text-sm text-gray-600">
            Real-time metrics on throughput, lag, partition distribution, and broker health.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            <h3 class="font-bold">Automated Backups</h3>
          </div>
          <p class="text-sm text-gray-600">
            Regular snapshots of cluster metadata and topic configurations with disaster recovery.
          </p>
        </div>

        <div class="bg-white rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
            <h3 class="font-bold">REST Proxy & APIs</h3>
          </div>
          <p class="text-sm text-gray-600">
            HTTP REST API for producers and consumers when native protocol isn't feasible.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Section -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">vs. Other Streaming Platforms</h2>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-4 text-left">Feature</th>
              <th class="border p-4 text-center">Managed Kafka</th>
              <th class="border p-4 text-center">AWS Kinesis</th>
              <th class="border p-4 text-center">Pub/Sub</th>
              <th class="border p-4 text-center">Event Hubs</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-4">Multi-Cloud</td>
              <td class="border p-4 text-center">✓</td>
              <td class="border p-4 text-center text-gray-400">AWS Only</td>
              <td class="border p-4 text-center text-gray-400">GCP Only</td>
              <td class="border p-4 text-center text-gray-400">Azure Only</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Message Replay</td>
              <td class="border p-4 text-center">Unlimited</td>
              <td class="border p-4 text-center">7 days max</td>
              <td class="border p-4 text-center">7 days max</td>
              <td class="border p-4 text-center">90 days max</td>
            </tr>
            <tr>
              <td class="border p-4">Open Source</td>
              <td class="border p-4 text-center">✓ (Apache)</td>
              <td class="border p-4 text-center">✗ Proprietary</td>
              <td class="border p-4 text-center">✗ Proprietary</td>
              <td class="border p-4 text-center">✗ Proprietary</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Ecosystem</td>
              <td class="border p-4 text-center">Rich</td>
              <td class="border p-4 text-center">Limited</td>
              <td class="border p-4 text-center">Limited</td>
              <td class="border p-4 text-center">Moderate</td>
            </tr>
            <tr>
              <td class="border p-4">Exactly-Once</td>
              <td class="border p-4 text-center">✓</td>
              <td class="border p-4 text-center">✗</td>
              <td class="border p-4 text-center">At-least-once</td>
              <td class="border p-4 text-center">✓</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-br from-purple-600 to-indigo-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Stream at Scale?</h2>
      <p class="text-xl text-purple-100 mb-8">
        Get started with enterprise Kafka without the operational overhead
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-white text-purple-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition">
          Request Demo
        </a>
        <a href="/#pricing" class="border-2 border-white text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-white hover:text-purple-600 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
