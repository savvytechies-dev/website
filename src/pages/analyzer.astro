---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Keycloak Analyzer — Instant Security Audit | SavvyTechies"
  description="Paste a Keycloak realm export for an instant, AI-assisted security & production-readiness audit. Nothing is stored — the export is analyzed in memory and discarded."
>
  <Navigation />

  <section class="bg-gradient-to-br from-primary-600 to-secondary-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Keycloak Analyzer</h1>
      <p class="text-xl text-indigo-100 mb-4">
        Paste a realm export → an instant, AI-assisted security &amp; production-readiness audit.
      </p>
      <p class="inline-flex items-center gap-2 text-sm bg-white/15 rounded-full px-4 py-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        Nothing is stored — analyzed in memory, then discarded.
      </p>
    </div>
  </section>

  <section class="py-12 bg-gray-50 min-h-[60vh]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="az-input">
        <label for="az-text" class="block text-sm font-semibold text-gray-700 mb-2">
          Realm export (JSON)
        </label>
        <textarea
          id="az-text"
          rows="12"
          spellcheck="false"
          class="w-full font-mono text-xs p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
          placeholder='{ "realm": "acme-prod", "sslRequired": "external", "clients": [ ... ] }'
        ></textarea>
        <div class="flex items-center gap-3 mt-3 flex-wrap">
          <button id="az-run" class="bg-primary-600 hover:bg-primary-700 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-50">
            Analyze
          </button>
          <label class="cursor-pointer text-sm font-medium text-primary-600 hover:text-primary-700">
            Upload .json
            <input id="az-file" type="file" accept=".json,application/json" class="hidden" />
          </label>
          <span id="az-error" class="text-sm text-red-600"></span>
        </div>
        <div class="flex items-center gap-2 mt-3 text-sm">
          <span class="text-gray-500">No export handy? Load an example:</span>
          <button data-example="hardened" class="text-green-700 font-medium hover:underline">Hardened (A)</button>
          <span class="text-gray-300">·</span>
          <button data-example="weak" class="text-red-600 font-medium hover:underline">Needs work (F)</button>
        </div>
        <p class="text-xs text-gray-500 mt-3">
          In Keycloak: <span class="font-mono">Realm settings → Action → Partial export</span>. Export
          without users. Max 3&nbsp;MB. This tool is stateless and requires no account.
        </p>
      </div>

      <div id="az-report" class="hidden"></div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const API = 'https://analyzer.savvytechies.com/analyze';
  const MAX = 3 * 1024 * 1024;

  // Sample realm exports so visitors can try the tool without their own file.
  const EXAMPLES = {
    hardened: {
      realm: 'acme-prod',
      enabled: true,
      sslRequired: 'external',
      bruteForceProtected: true,
      permanentLockout: false,
      passwordPolicy: 'length(12) and notUsername and notEmail',
      registrationAllowed: false,
      verifyEmail: true,
      accessTokenLifespan: 300,
      ssoSessionIdleTimeout: 1800,
      ssoSessionMaxLifespan: 36000,
      revokeRefreshToken: true,
      eventsEnabled: true,
      adminEventsEnabled: true,
      browserSecurityHeaders: { xFrameOptions: 'SAMEORIGIN' },
      clients: [
        { clientId: 'acme-spa', publicClient: true, standardFlowEnabled: true, implicitFlowEnabled: false,
          redirectUris: ['https://app.acme.com/callback'], webOrigins: ['https://app.acme.com'],
          attributes: { 'pkce.code.challenge.method': 'S256' } },
        { clientId: 'acme-backend', publicClient: false, standardFlowEnabled: true,
          redirectUris: ['https://api.acme.com/callback'], webOrigins: ['https://api.acme.com'] },
      ],
    },
    weak: {
      realm: 'acme-prod',
      enabled: true,
      sslRequired: 'external',
      bruteForceProtected: true,
      passwordPolicy: '',
      registrationAllowed: true,
      verifyEmail: false,
      accessTokenLifespan: 3600,
      ssoSessionIdleTimeout: 1800,
      revokeRefreshToken: false,
      eventsEnabled: false,
      adminEventsEnabled: false,
      browserSecurityHeaders: { xFrameOptions: 'SAMEORIGIN' },
      clients: [
        { clientId: 'acme-spa', publicClient: true, standardFlowEnabled: true,
          redirectUris: ['https://app.acme.com/*'], webOrigins: ['*'], attributes: {} },
        { clientId: 'acme-backend', publicClient: false, standardFlowEnabled: true,
          redirectUris: ['https://api.acme.com/callback'], webOrigins: ['https://api.acme.com'] },
      ],
    },
  };
  const SEV = ['critical', 'high', 'medium', 'low', 'info'];
  const SEVBG = { critical: '#b42318', high: '#dc2626', medium: '#d97706', low: '#64748b', info: '#16a34a' };

  const $ = (id) => document.getElementById(id);
  const esc = (s) =>
    String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]);

  function gradeColor(g) {
    if (g === 'A' || g === 'B') return '#16a34a';
    if (g === 'C') return '#d97706';
    return '#dc2626';
  }

  function pill(sev, label) {
    return `<span style="background:${SEVBG[sev] || '#64748b'}" class="text-white text-[11px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full">${esc(label || sev)}</span>`;
  }

  function render(r) {
    const counts = SEV.map((s) => (r.counts?.[s] ? pill(s, `${r.counts[s]} ${s}`) : '')).join(' ');
    const summary = r.summary
      ? `<div class="bg-gray-100 border border-gray-200 rounded-xl p-4 mb-5">
           <div class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1">AI summary</div>
           <div class="text-sm whitespace-pre-wrap leading-relaxed">${esc(r.summary)}</div></div>`
      : '';
    const findings = (r.findings || [])
      .map(
        (f) => `<li class="border border-gray-200 rounded-xl p-4">
          <div class="flex items-center gap-2 flex-wrap">
            ${pill(f.severity)}
            <span class="font-semibold">${esc(f.title)}</span>
            <span class="ml-auto text-xs text-gray-500">${esc(f.category)}</span>
          </div>
          <div class="text-sm mt-2">${esc(f.detail)}</div>
          <div class="text-sm text-gray-600 mt-1"><strong>Fix:</strong> ${esc(f.recommendation)}</div>
        </li>`,
      )
      .join('');
    const passed =
      r.passed && r.passed.length
        ? `<details class="mt-4 text-sm text-gray-600"><summary class="cursor-pointer font-semibold">${r.passed.length} checks passed</summary>
           <ul class="mt-2 space-y-1">${r.passed.map((p) => `<li>✓ ${esc(p)}</li>`).join('')}</ul></details>`
        : '';

    $('az-report').innerHTML = `
      <div class="flex items-center gap-5 mb-5">
        <div style="background:${gradeColor(r.grade)}" class="w-24 h-24 rounded-2xl flex flex-col items-center justify-center text-white shrink-0">
          <div class="text-4xl font-extrabold leading-none">${esc(r.grade)}</div>
          <div class="text-xs font-semibold opacity-90 mt-1">${r.score}/100</div>
        </div>
        <div>
          <div class="text-lg">Realm <strong>${esc(r.realm)}</strong> · ${r.clientCount} client${r.clientCount === 1 ? '' : 's'}</div>
          <div class="flex flex-wrap gap-2 mt-2">${counts || pill('info', 'no findings')}</div>
        </div>
      </div>
      ${summary}
      <ul class="space-y-3">${findings}</ul>
      ${passed}
      <button id="az-reset" class="mt-6 text-sm font-medium text-primary-600 hover:text-primary-700">← Analyze another export</button>`;

    $('az-input').classList.add('hidden');
    $('az-report').classList.remove('hidden');
    $('az-reset').addEventListener('click', () => {
      $('az-report').classList.add('hidden');
      $('az-input').classList.remove('hidden');
      $('az-text').value = '';
    });
  }

  async function analyze() {
    const text = $('az-text').value.trim();
    $('az-error').textContent = '';
    if (!text) return;
    if (text.length > MAX) {
      $('az-error').textContent = 'That export is too large (max 3 MB).';
      return;
    }
    const btn = $('az-run');
    btn.disabled = true;
    btn.textContent = 'Analyzing…';
    try {
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: text,
        cache: 'no-store',
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || `Request failed (${res.status})`);
      render(data);
    } catch (e) {
      $('az-error').textContent = e instanceof Error ? e.message : 'Analysis failed';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Analyze';
    }
  }

  $('az-run').addEventListener('click', analyze);
  document.querySelectorAll('[data-example]').forEach((b) =>
    b.addEventListener('click', () => {
      const key = b.getAttribute('data-example');
      $('az-text').value = JSON.stringify(EXAMPLES[key], null, 2);
      $('az-error').textContent = '';
    }),
  );
  $('az-file').addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    e.target.value = '';
    if (!file) return;
    if (file.size > MAX) {
      $('az-error').textContent = 'That file is too large (max 3 MB).';
      return;
    }
    const reader = new FileReader();
    reader.onload = () => ($('az-text').value = String(reader.result));
    reader.readAsText(file);
  });

  // Seed the box so the tool is never a blank wall — a sample "needs work" export
  // the visitor can Analyze immediately (or swap via the example buttons / upload).
  if (!$('az-text').value) $('az-text').value = JSON.stringify(EXAMPLES.weak, null, 2);
</script>
