---
---

<nav class="bg-white shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <a href="/" class="flex items-center">
          <span class="text-2xl font-bold text-primary-600">SavvyTechies</span>
        </a>
      </div>

      <div class="hidden md:flex items-center space-x-8">
        <a href="/#services" class="text-gray-700 hover:text-primary-600 transition">Services</a>
        <a href="/#pricing" class="text-gray-700 hover:text-primary-600 transition">Pricing</a>
        <a href="/architecture" class="text-gray-700 hover:text-primary-600 transition">Architecture</a>
        <a href="/analyzer" class="text-gray-700 hover:text-primary-600 transition">Analyzer</a>
        <a href="/docs/" class="text-gray-700 hover:text-primary-600 transition">Docs</a>
        <a href="/security" class="text-gray-700 hover:text-primary-600 transition">Security</a>
        <a href="https://status.savvytechies.com" class="text-gray-700 hover:text-primary-600 transition">Status</a>
        <a href="https://console.savvytechies.com/signup" class="bg-secondary-600 text-white px-4 py-2 rounded-lg hover:bg-secondary-700 transition font-semibold">
          Start Free Trial
        </a>
        <a href="/#contact" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition">
          Contact Sales
        </a>
      </div>

      <div class="md:hidden flex items-center">
        <button id="mobile-menu-button" class="text-gray-700">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <div class="px-2 pt-2 pb-3 space-y-1">
      <a href="/#services" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Services</a>
      <a href="/#pricing" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Pricing</a>
      <a href="/architecture" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Architecture</a>
      <a href="/analyzer" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Analyzer</a>
      <a href="/docs/" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Docs</a>
      <a href="/security" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Security</a>
      <a href="https://status.savvytechies.com" class="block px-3 py-2 text-gray-700 hover:bg-gray-100">Status</a>
      <a href="https://console.savvytechies.com/signup" class="block px-3 py-2 bg-secondary-600 text-white text-center rounded-lg font-semibold mb-2">Start Free Trial</a>
      <a href="/#contact" class="block px-3 py-2 bg-primary-600 text-white text-center rounded-lg">Contact Sales</a>
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
